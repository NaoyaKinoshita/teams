# Entra ID アプリ登録の値（Azure Portal → Entra ID → アプリの登録）
MICROSOFT_APP_ID=your_app_id
MICROSOFT_APP_SECRET=your_app_secret
TENANT_ID=your_tenant_id

# このサーバー自身の公開 URL
# Graph API がここに変更通知（録画イベント等）を POST してくる
# ローカル開発時は ngrok の URL、本番は Container Apps の FQDN を設定する
# → manifest.json の <SERVER_URL> と同じホスト名
NOTIFICATION_URL=https://your-server-url

# 録画が OneDrive に保存された際に通知する先の URL
# Azure Functions など、録画データを受け取る側のエンドポイント
AZURE_WEBHOOK_URL=https://your-functions-url/api/recording-stopped

# Bot サーバーのポート番号
PORT=8000

# Teams 管理センターで確認できるアプリカタログ ID
# 「Teams アプリ」→「アプリの管理」でアプリを選択したときの「アプリ ID」
# ※ manifest.json の id フィールドとは別物
TEAMS_APP_ID=your_teams_app_catalog_id
