# Entra ID アプリ登録の値
MICROSOFT_APP_ID=your_app_id
MICROSOFT_APP_SECRET=your_app_secret
TENANT_ID=your_tenant_id

# ngrok などの公開 URL（Graph API の Webhook 受信に必要）
# 例: https://xxxx-xx-xx-xxx-xx.ngrok-free.app
NOTIFICATION_URL=https://your-ngrok-url

# Teams 会議に招待する録画用ユーザーのオブジェクト ID
RECORDING_BOT_USER_ID=your_recording_bot_user_object_id

# 録画停止時に通知する Azure Webhook URL（Azure Functions HTTP トリガーなど）
# 未設定の場合は通知をスキップ
AZURE_WEBHOOK_URL=

# Bot サーバーのポート番号
PORT=3978
